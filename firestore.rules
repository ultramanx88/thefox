rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===========================================
    // USERS COLLECTION
    // ===========================================
    match /users/{userId} {
      // Users can read/write their own data
      allow read, write: if isAuthenticated() && isOwner(userId);
      
      // Admins can read all users
      allow read: if isAuthenticated() && hasRole('admin');
      
      // Allow user creation during registration
      allow create: if isAuthenticated() && 
        request.auth.uid == userId &&
        isValidUserData(request.resource.data);
      
      // Allow profile updates with validation
      allow update: if isAuthenticated() && 
        (isOwner(userId) || hasRole('admin')) &&
        isValidUserUpdate(resource.data, request.resource.data);
    }

    // ===========================================
    // USER APPLICATIONS COLLECTION (Driver/Vendor)
    // ===========================================
    match /applications/{applicationId} {
      // Users can read their own applications
      allow read: if isAuthenticated() && isOwner(resource.data.userId);
      
      // Admins can read all applications
      allow read: if isAuthenticated() && hasRole('admin');
      
      // Users can create applications for themselves
      allow create: if isAuthenticated() && 
        request.auth.uid == request.resource.data.userId &&
        isValidApplicationData(request.resource.data);
      
      // Only admins can update applications (for approval/rejection)
      allow update: if isAuthenticated() && hasRole('admin') &&
        isValidApplicationUpdate(resource.data, request.resource.data);
    }

    // ===========================================
    // VERIFICATION TOKENS COLLECTION
    // ===========================================
    match /verificationTokens/{tokenId} {
      // Only the system can manage verification tokens
      allow read, write: if isAuthenticated() && hasRole('admin');
      
      // Allow token creation during verification process
      allow create: if isAuthenticated() &&
        isValidVerificationToken(request.resource.data);
    }
    
    // ===========================================
    // MARKETS COLLECTION
    // ===========================================
    match /markets/{marketId} {
      // Public read access for browsing
      allow read: if true;
      
      // Market owners can create/update their markets
      allow create: if isAuthenticated() && 
        request.auth.uid == request.resource.data.ownerId &&
        isValidMarketData(request.resource.data);
      
      // Market owners and admins can update
      allow update: if isAuthenticated() && 
        (isOwner(resource.data.ownerId) || hasRole('admin')) &&
        isValidMarketUpdate(resource.data, request.resource.data);
      
      // Only admins can delete markets
      allow delete: if isAuthenticated() && hasRole('admin');
    }
    
    // ===========================================
    // PRODUCTS COLLECTION
    // ===========================================
    match /products/{productId} {
      // Public read access for browsing
      allow read: if true;
      
      // Market owners can create products for their markets
      allow create: if isAuthenticated() && 
        isMarketOwner(request.resource.data.marketId) &&
        isValidProductData(request.resource.data);
      
      // Market owners and admins can update products
      allow update: if isAuthenticated() && 
        (isMarketOwner(resource.data.marketId) || hasRole('admin')) &&
        isValidProductUpdate(resource.data, request.resource.data);
      
      // Market owners and admins can delete products
      allow delete: if isAuthenticated() && 
        (isMarketOwner(resource.data.marketId) || hasRole('admin'));
    }
    
    // ===========================================
    // ORDERS COLLECTION
    // ===========================================
    match /orders/{orderId} {
      // Users can read their own orders
      // Market owners can read orders for their markets
      // Drivers can read assigned orders
      // Admins can read all orders
      allow read: if isAuthenticated() && 
        (isOwner(resource.data.userId) || 
         isMarketOwner(resource.data.marketId) ||
         isOwner(resource.data.driverId) ||
         hasRole('admin'));
      
      // Users can create orders for themselves
      allow create: if isAuthenticated() && 
        request.auth.uid == request.resource.data.userId &&
        isValidOrderData(request.resource.data);
      
      // Order updates allowed by relevant parties
      allow update: if isAuthenticated() && 
        (isOwner(resource.data.userId) || 
         isMarketOwner(resource.data.marketId) ||
         isOwner(resource.data.driverId) ||
         hasRole('admin')) &&
        isValidOrderUpdate(resource.data, request.resource.data);
      
      // Only admins can delete orders
      allow delete: if isAuthenticated() && hasRole('admin');
    }
    
    // ===========================================
    // CATEGORIES COLLECTION
    // ===========================================
    match /categories/{categoryId} {
      // Public read access
      allow read: if true;
      
      // Only admins can manage categories
      allow write: if isAuthenticated() && hasRole('admin') &&
        isValidCategoryData(request.resource.data);
    }
    
    // ===========================================
    // SERVICE AREAS COLLECTION
    // ===========================================
    match /serviceAreas/{areaId} {
      // Public read access
      allow read: if true;
      
      // Only admins can manage service areas
      allow write: if isAuthenticated() && hasRole('admin') &&
        isValidServiceAreaData(request.resource.data);
    }
    
    // ===========================================
    // NOTIFICATIONS COLLECTION
    // ===========================================
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if isAuthenticated() && 
        isOwner(resource.data.userId);
      
      // System can create notifications
      allow create: if isAuthenticated() &&
        isValidNotificationData(request.resource.data);
      
      // Users can update notification status (read/unread)
      allow update: if isAuthenticated() && 
        isOwner(resource.data.userId) &&
        isValidNotificationUpdate(resource.data, request.resource.data);
      
      // Users can delete their notifications
      allow delete: if isAuthenticated() && 
        isOwner(resource.data.userId);
    }
    
    // ===========================================
    // REVIEWS COLLECTION
    // ===========================================
    match /reviews/{reviewId} {
      // Public read access
      allow read: if true;
      
      // Users can create reviews for their orders
      allow create: if isAuthenticated() &&
        isOwner(request.resource.data.userId) &&
        isValidReviewData(request.resource.data);
      
      // Users can update their own reviews
      allow update: if isAuthenticated() && 
        (isOwner(resource.data.userId) || hasRole('admin')) &&
        isValidReviewUpdate(resource.data, request.resource.data);
      
      // Users and admins can delete reviews
      allow delete: if isAuthenticated() && 
        (isOwner(resource.data.userId) || hasRole('admin'));
    }
    
    // ===========================================
    // DELIVERIES COLLECTION
    // ===========================================
    match /deliveries/{deliveryId} {
      // Relevant parties can read delivery info
      allow read: if isAuthenticated() && 
        (isOwner(resource.data.userId) || 
         isOwner(resource.data.driverId) ||
         isMarketOwner(resource.data.marketId) ||
         hasRole('admin'));
      
      // System creates deliveries
      allow create: if isAuthenticated() &&
        isValidDeliveryData(request.resource.data);
      
      // Drivers and admins can update delivery status
      allow update: if isAuthenticated() && 
        (isOwner(resource.data.driverId) || hasRole('admin')) &&
        isValidDeliveryUpdate(resource.data, request.resource.data);
    }
    
    // ===========================================
    // ANALYTICS COLLECTION (Admin only)
    // ===========================================
    match /analytics/{document=**} {
      allow read, write: if isAuthenticated() && hasRole('admin');
    }
    
    // ===========================================
    // SYSTEM SETTINGS COLLECTION (Admin only)
    // ===========================================
    match /settings/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasRole('admin');
    }
    
    // ===========================================
    // HELPER FUNCTIONS
    // ===========================================
    
    // Authentication helpers
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    function hasRole(role) {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    function isMarketOwner(marketId) {
      return request.auth != null && 
        get(/databases/$(database)/documents/markets/$(marketId)).data.ownerId == request.auth.uid;
    }
    
    // Data validation functions
    function isValidUserData(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'status', 'profile', 'verification', 'createdAt']) &&
        data.role in ['customer', 'vendor', 'driver', 'admin'] &&
        data.status in ['pending', 'active', 'suspended', 'rejected'] &&
        data.email is string &&
        data.uid is string &&
        data.profile is map &&
        data.verification is map &&
        data.createdAt is timestamp;
    }
    
    function isValidUserUpdate(oldData, newData) {
      // Prevent role and status changes by non-admins
      return (oldData.role == newData.role || hasRole('admin')) &&
        (oldData.status == newData.status || hasRole('admin')) &&
        newData.email is string &&
        newData.uid is string &&
        newData.profile is map &&
        newData.verification is map;
    }

    function isValidApplicationData(data) {
      return data.keys().hasAll(['userId', 'type', 'status', 'userData', 'documents', 'submittedAt']) &&
        data.type in ['driver', 'vendor'] &&
        data.status in ['pending', 'approved', 'rejected'] &&
        data.userId is string &&
        data.userData is map &&
        data.documents is list &&
        data.submittedAt is timestamp;
    }
    
    function isValidApplicationUpdate(oldData, newData) {
      // Prevent changing core application data
      return oldData.userId == newData.userId &&
        oldData.type == newData.type &&
        oldData.userData == newData.userData &&
        oldData.documents == newData.documents &&
        newData.status in ['pending', 'approved', 'rejected'];
    }

    function isValidVerificationToken(data) {
      return data.keys().hasAll(['userId', 'type', 'token', 'expiresAt', 'createdAt']) &&
        data.type in ['email', 'sms'] &&
        data.userId is string &&
        data.token is string &&
        data.expiresAt is timestamp &&
        data.createdAt is timestamp;
    }
    
    function isValidMarketData(data) {
      return data.keys().hasAll(['name', 'ownerId', 'address', 'location', 'isOpen', 'createdAt']) &&
        data.name is string &&
        data.ownerId is string &&
        data.address is string &&
        data.location is latlng &&
        data.isOpen is bool &&
        data.createdAt is timestamp;
    }
    
    function isValidMarketUpdate(oldData, newData) {
      // Prevent owner changes
      return oldData.ownerId == newData.ownerId &&
        newData.name is string &&
        newData.address is string &&
        newData.location is latlng &&
        newData.isOpen is bool;
    }
    
    function isValidProductData(data) {
      return data.keys().hasAll(['name', 'marketId', 'price', 'category', 'inStock', 'createdAt']) &&
        data.name is string &&
        data.marketId is string &&
        data.price is number &&
        data.price > 0 &&
        data.category is string &&
        data.inStock is bool &&
        data.createdAt is timestamp;
    }
    
    function isValidProductUpdate(oldData, newData) {
      // Prevent market changes
      return oldData.marketId == newData.marketId &&
        newData.name is string &&
        newData.price is number &&
        newData.price > 0 &&
        newData.category is string &&
        newData.inStock is bool;
    }
    
    function isValidOrderData(data) {
      return data.keys().hasAll(['userId', 'marketId', 'items', 'status', 'totalAmount', 'createdAt']) &&
        data.userId is string &&
        data.marketId is string &&
        data.items is list &&
        data.items.size() > 0 &&
        data.status in ['pending', 'confirmed', 'preparing', 'ready', 'delivering', 'delivered', 'cancelled'] &&
        data.totalAmount is number &&
        data.totalAmount > 0 &&
        data.createdAt is timestamp;
    }
    
    function isValidOrderUpdate(oldData, newData) {
      // Prevent user and market changes
      return oldData.userId == newData.userId &&
        oldData.marketId == newData.marketId &&
        newData.status in ['pending', 'confirmed', 'preparing', 'ready', 'delivering', 'delivered', 'cancelled'];
    }
    
    function isValidCategoryData(data) {
      return data.keys().hasAll(['name', 'description', 'isActive', 'createdAt']) &&
        data.name is string &&
        data.description is string &&
        data.isActive is bool &&
        data.createdAt is timestamp;
    }
    
    function isValidServiceAreaData(data) {
      return data.keys().hasAll(['name', 'boundaries', 'isActive', 'createdAt']) &&
        data.name is string &&
        data.boundaries is list &&
        data.isActive is bool &&
        data.createdAt is timestamp;
    }
    
    function isValidNotificationData(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type', 'isRead', 'createdAt']) &&
        data.userId is string &&
        data.title is string &&
        data.message is string &&
        data.type in ['order', 'delivery', 'system', 'promotion'] &&
        data.isRead is bool &&
        data.createdAt is timestamp;
    }
    
    function isValidNotificationUpdate(oldData, newData) {
      // Only allow updating read status
      return oldData.userId == newData.userId &&
        oldData.title == newData.title &&
        oldData.message == newData.message &&
        oldData.type == newData.type &&
        newData.isRead is bool;
    }
    
    function isValidReviewData(data) {
      return data.keys().hasAll(['userId', 'marketId', 'orderId', 'rating', 'comment', 'createdAt']) &&
        data.userId is string &&
        data.marketId is string &&
        data.orderId is string &&
        data.rating is number &&
        data.rating >= 1 &&
        data.rating <= 5 &&
        data.comment is string &&
        data.createdAt is timestamp;
    }
    
    function isValidReviewUpdate(oldData, newData) {
      // Prevent changing core review data
      return oldData.userId == newData.userId &&
        oldData.marketId == newData.marketId &&
        oldData.orderId == newData.orderId &&
        newData.rating is number &&
        newData.rating >= 1 &&
        newData.rating <= 5 &&
        newData.comment is string;
    }
    
    function isValidDeliveryData(data) {
      return data.keys().hasAll(['orderId', 'userId', 'driverId', 'marketId', 'status', 'createdAt']) &&
        data.orderId is string &&
        data.userId is string &&
        data.driverId is string &&
        data.marketId is string &&
        data.status in ['assigned', 'picked_up', 'in_transit', 'delivered', 'failed'] &&
        data.createdAt is timestamp;
    }
    
    function isValidDeliveryUpdate(oldData, newData) {
      // Prevent changing core delivery data
      return oldData.orderId == newData.orderId &&
        oldData.userId == newData.userId &&
        oldData.driverId == newData.driverId &&
        oldData.marketId == newData.marketId &&
        newData.status in ['assigned', 'picked_up', 'in_transit', 'delivered', 'failed'];
    }
  }
}