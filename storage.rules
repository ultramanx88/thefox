rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // ===========================================
    // USER PROFILE FILES
    // ===========================================
    
    // User profile images (avatars)
    match /users/{userId}/profile/avatar/{fileName} {
      allow read: if true; // Public read access for profile images
      allow write: if isAuthenticated() && 
        isOwner(userId) && 
        isValidImageFile() &&
        isValidFileName(fileName);
      allow delete: if isAuthenticated() && 
        (isOwner(userId) || hasRole('admin'));
    }
    
    // User documents (ID, licenses, etc.)
    match /users/{userId}/documents/{fileName} {
      allow read: if isAuthenticated() && 
        (isOwner(userId) || hasRole('admin'));
      allow write: if isAuthenticated() && 
        isOwner(userId) && 
        isValidDocumentFile() &&
        isValidFileName(fileName);
      allow delete: if isAuthenticated() && 
        (isOwner(userId) || hasRole('admin'));
    }
    
    // Driver specific documents
    match /users/{userId}/driver/{docType}/{fileName} {
      allow read: if isAuthenticated() && 
        (isOwner(userId) || hasRole('admin'));
      allow write: if isAuthenticated() && 
        isOwner(userId) && 
        hasRole('driver') &&
        docType in ['license', 'vehicle', 'insurance'] &&
        isValidDocumentFile() &&
        isValidFileName(fileName);
      allow delete: if isAuthenticated() && 
        (isOwner(userId) || hasRole('admin'));
    }
    
    // ===========================================
    // MARKET FILES
    // ===========================================
    
    // Market profile images
    match /markets/{marketId}/profile/{fileName} {
      allow read: if true; // Public read access
      allow write: if isAuthenticated() && 
        (isMarketOwner(marketId) || hasRole('admin')) &&
        isValidImageFile() &&
        isValidFileName(fileName);
      allow delete: if isAuthenticated() && 
        (isMarketOwner(marketId) || hasRole('admin'));
    }
    
    // Market gallery images
    match /markets/{marketId}/gallery/{fileName} {
      allow read: if true; // Public read access
      allow write: if isAuthenticated() && 
        (isMarketOwner(marketId) || hasRole('admin')) &&
        isValidImageFile() &&
        isValidFileName(fileName);
      allow delete: if isAuthenticated() && 
        (isMarketOwner(marketId) || hasRole('admin'));
    }
    
    // Market business documents
    match /markets/{marketId}/documents/{docType}/{fileName} {
      allow read: if isAuthenticated() && 
        (isMarketOwner(marketId) || hasRole('admin'));
      allow write: if isAuthenticated() && 
        (isMarketOwner(marketId) || hasRole('admin')) &&
        docType in ['license', 'permit', 'certificate', 'tax'] &&
        isValidDocumentFile() &&
        isValidFileName(fileName);
      allow delete: if isAuthenticated() && 
        (isMarketOwner(marketId) || hasRole('admin'));
    }
    
    // ===========================================
    // PRODUCT FILES
    // ===========================================
    
    // Product images
    match /products/{productId}/images/{fileName} {
      allow read: if true; // Public read access
      allow write: if isAuthenticated() && 
        (isProductOwner(productId) || hasRole('admin')) &&
        isValidImageFile() &&
        isValidFileName(fileName);
      allow delete: if isAuthenticated() && 
        (isProductOwner(productId) || hasRole('admin'));
    }
    
    // Product thumbnails (auto-generated)
    match /products/{productId}/thumbnails/{fileName} {
      allow read: if true; // Public read access
      allow write: if isAuthenticated() && 
        (isProductOwner(productId) || hasRole('admin')) &&
        isValidImageFile() &&
        isValidFileName(fileName);
      allow delete: if isAuthenticated() && 
        (isProductOwner(productId) || hasRole('admin'));
    }
    
    // ===========================================
    // ORDER FILES
    // ===========================================
    
    // Order receipts and invoices
    match /orders/{orderId}/receipts/{fileName} {
      allow read: if isAuthenticated() && 
        (isOrderOwner(orderId) || 
         isOrderMarketOwner(orderId) ||
         isOrderDriver(orderId) ||
         hasRole('admin'));
      allow write: if isAuthenticated() && 
        (isOrderMarketOwner(orderId) || hasRole('admin')) &&
        isValidDocumentFile() &&
        isValidFileName(fileName);
      allow delete: if isAuthenticated() && hasRole('admin');
    }
    
    // Order delivery photos
    match /orders/{orderId}/delivery/{fileName} {
      allow read: if isAuthenticated() && 
        (isOrderOwner(orderId) || 
         isOrderMarketOwner(orderId) ||
         isOrderDriver(orderId) ||
         hasRole('admin'));
      allow write: if isAuthenticated() && 
        isOrderDriver(orderId) &&
        isValidImageFile() &&
        isValidFileName(fileName);
      allow delete: if isAuthenticated() && 
        (isOrderDriver(orderId) || hasRole('admin'));
    }
    
    // ===========================================
    // CATEGORY FILES
    // ===========================================
    
    // Category icons and images
    match /categories/{categoryId}/images/{fileName} {
      allow read: if true; // Public read access
      allow write: if isAuthenticated() && 
        hasRole('admin') &&
        isValidImageFile() &&
        isValidFileName(fileName);
      allow delete: if isAuthenticated() && hasRole('admin');
    }
    
    // ===========================================
    // SYSTEM FILES
    // ===========================================
    
    // App branding and assets (admin only)
    match /system/branding/{fileName} {
      allow read: if true; // Public read access
      allow write: if isAuthenticated() && 
        hasRole('admin') &&
        isValidImageFile() &&
        isValidFileName(fileName);
      allow delete: if isAuthenticated() && hasRole('admin');
    }
    
    // System templates and documents
    match /system/templates/{fileName} {
      allow read: if isAuthenticated() && hasRole('admin');
      allow write: if isAuthenticated() && 
        hasRole('admin') &&
        isValidDocumentFile() &&
        isValidFileName(fileName);
      allow delete: if isAuthenticated() && hasRole('admin');
    }
    
    // ===========================================
    // TEMPORARY UPLOADS
    // ===========================================
    
    // Temporary upload area (24-hour TTL)
    match /temp/{userId}/{uploadId}/{fileName} {
      allow read, write: if isAuthenticated() && 
        isOwner(userId) &&
        isValidTempFile() &&
        isValidFileName(fileName);
      allow delete: if isAuthenticated() && 
        (isOwner(userId) || hasRole('admin'));
    }
    
    // ===========================================
    // BACKUP AND EXPORTS (Admin only)
    // ===========================================
    
    match /backups/{fileName} {
      allow read, write: if isAuthenticated() && hasRole('admin');
    }
    
    match /exports/{fileName} {
      allow read, write: if isAuthenticated() && hasRole('admin');
    }
    
    // ===========================================
    // HELPER FUNCTIONS
    // ===========================================
    
    // Authentication helpers
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    function hasRole(role) {
      return request.auth != null && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    // Ownership verification functions
    function isMarketOwner(marketId) {
      return request.auth != null && 
        firestore.get(/databases/(default)/documents/markets/$(marketId)).data.ownerId == request.auth.uid;
    }
    
    function isProductOwner(productId) {
      let product = firestore.get(/databases/(default)/documents/products/$(productId));
      return request.auth != null && 
        firestore.get(/databases/(default)/documents/markets/$(product.data.marketId)).data.ownerId == request.auth.uid;
    }
    
    function isOrderOwner(orderId) {
      return request.auth != null && 
        firestore.get(/databases/(default)/documents/orders/$(orderId)).data.userId == request.auth.uid;
    }
    
    function isOrderMarketOwner(orderId) {
      let order = firestore.get(/databases/(default)/documents/orders/$(orderId));
      return request.auth != null && 
        firestore.get(/databases/(default)/documents/markets/$(order.data.marketId)).data.ownerId == request.auth.uid;
    }
    
    function isOrderDriver(orderId) {
      let order = firestore.get(/databases/(default)/documents/orders/$(orderId));
      return request.auth != null && 
        order.data.driverId != null &&
        order.data.driverId == request.auth.uid;
    }
    
    // File validation functions
    function isValidImageFile() {
      return request.resource != null &&
        request.resource.contentType.matches('image/(jpeg|jpg|png|gif|webp)') &&
        request.resource.size < 5 * 1024 * 1024 && // 5MB limit
        request.resource.size > 0;
    }
    
    function isValidDocumentFile() {
      return request.resource != null &&
        request.resource.contentType.matches('application/(pdf|msword|vnd.openxmlformats-officedocument.wordprocessingml.document)') &&
        request.resource.size < 10 * 1024 * 1024 && // 10MB limit
        request.resource.size > 0;
    }
    
    function isValidTempFile() {
      return request.resource != null &&
        (isValidImageFile() || isValidDocumentFile()) &&
        request.resource.size < 20 * 1024 * 1024; // 20MB limit for temp files
    }
    
    function isValidFileName(fileName) {
      return fileName.matches('[a-zA-Z0-9._-]+') && // Alphanumeric, dots, underscores, hyphens only
        fileName.size() > 0 &&
        fileName.size() < 100 && // Max 100 characters
        !fileName.matches('.*\\.\\..*') && // No double dots
        !fileName.matches('^\\..*') && // No leading dot
        !fileName.matches('.*\\.$'); // No trailing dot
    }
    
    // Rate limiting helper (basic implementation)
    function isWithinRateLimit() {
      // This is a simplified rate limiting check
      // In production, you might want to implement more sophisticated rate limiting
      return request.time > resource.timeCreated + duration.value(1, 's');
    }
  }
}