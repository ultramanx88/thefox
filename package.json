{
  "name": "thefox-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:web && npm run build:mobile",
    "build:web": "npm run build --workspace=apps/web",
    "build:mobile": "npm run build --workspace=apps/mobile",
    "dev": "npm run dev:web",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:mobile": "npm run dev --workspace=apps/mobile",
    "start": "npm run start:web",
    "start:web": "npm run start --workspace=apps/web",
    "start:mobile": "npm run start --workspace=apps/mobile",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "dev:backend": "cargo run --manifest-path backend/Cargo.toml"
  },
  "dependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "autoprefixer": "^10.4.21",
    "dotenv": "^16.4.5",
    "expo": "^53.0.23",
    "recharts": "^3.1.0"
  }
}
