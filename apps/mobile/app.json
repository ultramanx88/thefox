{
  "expo": {
    "name": "theFOX",
    "slug": "thefox-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "thefox",
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thefox.mobile"
    },
    "android": {
      "package": "com.thefox.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "apiUrl": "http://localhost:4000"
    }
  }
}
